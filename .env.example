# Пример файла переменных окружения
# Скопируйте этот файл в .env и заполните своими значениями
# cp .env.example .env

# URL Qdrant (опционально, по умолчанию http://qdrant:6333)
QDRANT_URL=http://qdrant:6333
OLLAMA_MODEL=qwen3:14b
OLLAMA_SEED=42
TRITON_URL=http://triton:8000
USE_TRITON=True

# GLM OCR для скан-PDF (внутри сети докера)
GLM_OCR_URL=http://ollama:11434/v1

# Gradio Auth
GRADIO_USER=admin
GRADIO_PASSWORD=admin

# Ollama Settings
OLLAMA_KEEP_ALIVE=-1
OLLAMA_NUM_CTX=16000
OLLAMA_BASE_URL=http://ollama:11434

# RAG Params
RETRIEVER_K=15
CHUNK_SIZE=1500
CHUNK_OVERLAP=100
SUMMARY_RETRIEVER_K=3
SUMMARIES_COLLECTION_NAME=rag_ti_summaries
